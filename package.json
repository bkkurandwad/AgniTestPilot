{
  "name": "agni-test-pilot",
  "version": "1.0.0",
  "description": "Agni Test Pilot Playwright Browser Automation & QA Agent",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --mac --win"
  },
  "dependencies": {
    "playwright": "^1.45.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "asar": false,
    "appId": "com.agni.testpilot",
    "productName": "AgniTestPilot",
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ]
  }
}
